{
  "name": "helpdesk-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "agent": "bun run apps/api/src/main.ts",
    "agent:mastra": "bun run apps/mastra-agent/src/main.ts",
    "chunks": "bun run packages/ingestion/src/ingest.ts",
    "embed": "bun run packages/ingestion/src/embed.ts",
    "search": "bun run packages/retrieval/src/search.ts"
  },
  "packageManager": "bun@1.2.4",
  "devDependencies": {
    "turbo": "^2"
  },
  "dependencies": {
    "razorpay": "^2.9.6"
  }
}
